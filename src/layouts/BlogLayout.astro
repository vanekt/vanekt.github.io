---
import Layout from "./Layout.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import type { Translations } from "../i18n/types";

interface Props {
  t: Translations;
  title: string;
  description: string;
  slug?: string;
  canonicalUrl?: string;
}

const { t, title, description, slug, canonicalUrl } = Astro.props;

const isRu = t.lang === "ru";
const homeUrl = isRu ? "/ru/" : "/";
const blogUrl = isRu ? "/ru/blog/" : "/blog/";
const altBlogBase = isRu ? "/blog" : "/ru/blog";
const altUrl = slug ? `${altBlogBase}/${slug}/` : `${altBlogBase}/`;
const altLabel = isRu ? "EN" : "RU";
---

<Layout
  title={title}
  description={description}
  lang={t.lang}
  canonicalUrl={canonicalUrl}
>
  <header
    class="sticky top-0 z-40 h-14 flex items-center justify-between px-5 lg:px-10
           bg-white/95 dark:bg-slate-950/95 backdrop-blur-sm
           border-b border-slate-100 dark:border-slate-800/50"
  >
    <div class="flex items-center gap-6">
      <a
        href={homeUrl}
        class="font-semibold text-sm text-slate-900 dark:text-slate-100 hover:text-violet-700 dark:hover:text-violet-400 transition-colors"
      >
        {t.sidebar.name}
      </a>
      <a
        href={blogUrl}
        class="text-xs font-medium tracking-widest uppercase text-violet-700 dark:text-violet-400"
      >
        {t.nav.blog}
      </a>
    </div>

    <div class="flex items-center gap-1">
      <ThemeToggle />
      <a
        href={altUrl}
        class="w-9 h-9 flex items-center justify-center rounded-lg text-xs font-medium uppercase tracking-widest text-slate-500 dark:text-slate-400 hover:text-violet-700 dark:hover:text-violet-400 transition-colors"
      >
        {altLabel}
      </a>
    </div>
  </header>

  <main id="main-content" class="max-w-3xl mx-auto px-5 lg:px-8 py-12 lg:py-16">
    <slot />
  </main>
</Layout>
