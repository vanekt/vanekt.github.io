---
import CvLayout from "../layouts/CvLayout.astro";
import CvDocument from "../components/CvDocument.astro";
import { en as t } from "../i18n/en";
import { ENCODED_EMAIL } from "../utils/email";
import { cvSummaryEn, cvSkillsEn, cvExperienceEn, cvEducationEn, cvLanguagesEn } from "../data/cvContent";

const email = Buffer.from(ENCODED_EMAIL, "base64").toString();
---

<CvLayout title="Ivan Tkachenko — CV" lang="en">
  <CvDocument
    t={t}
    email={email}
    summaryTitle="Professional Summary"
    cvSkills={cvSkillsEn}
    cvSummary={cvSummaryEn}
    cvExperience={cvExperienceEn}
    cvEducation={cvEducationEn}
    cvLanguages={cvLanguagesEn}
    educationTitle="Education"
    languagesTitle="Languages"
  />
</CvLayout>
