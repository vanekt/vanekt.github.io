---
import CvLayout from "../../layouts/CvLayout.astro";
import CvDocument from "../../components/CvDocument.astro";
import { ru as t } from "../../i18n/ru";
import { ENCODED_EMAIL, ENCODED_WHATSAPP } from "../../utils/email";
import { cvSummaryRu, cvSkillsRu, cvExperienceRu, cvEducationRu, cvLanguagesRu } from "../../data/cvContent";

const email = Buffer.from(ENCODED_EMAIL, "base64").toString();
const whatsapp = Buffer.from(ENCODED_WHATSAPP, "base64").toString();
---

<CvLayout title="Иван Ткаченко — CV" lang="ru">
  <CvDocument
    t={t}
    email={email}
    whatsapp={whatsapp}
    summaryTitle="Обо мне"
    cvSkills={cvSkillsRu}
    cvSummary={cvSummaryRu}
    cvExperience={cvExperienceRu}
    cvEducation={cvEducationRu}
    cvLanguages={cvLanguagesRu}
    educationTitle="Образование"
    languagesTitle="Языки"
  />
</CvLayout>
