---
import { getCollection, render } from "astro:content";
import BlogLayout from "../../../layouts/BlogLayout.astro";
import { ru as t } from "../../../i18n/ru";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => data.lang === "ru" && !data.draft);
  return posts.map((post) => ({
    params: { slug: post.data.urlSlug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const dateFormatter = new Intl.DateTimeFormat("ru", { year: "numeric", month: "long", day: "numeric" });
const canonicalUrl = `https://vanekt.github.io/ru/blog/${post.data.urlSlug}/`;
---

<BlogLayout
  t={t}
  title={`${post.data.title} — Иван Ткаченко`}
  description={post.data.description}
  slug={post.data.urlSlug}
  canonicalUrl={canonicalUrl}
  cover={post.data.cover}
  alternates={[
    { hreflang: "x-default", href: `https://vanekt.github.io/blog/${post.data.urlSlug}/` },
    { hreflang: "en", href: `https://vanekt.github.io/blog/${post.data.urlSlug}/` },
    { hreflang: "ru", href: `https://vanekt.github.io/ru/blog/${post.data.urlSlug}/` },
  ]}
>
  <a
    href="/ru/blog/"
    class="inline-flex items-center text-sm text-slate-500 dark:text-slate-400 hover:text-violet-700 dark:hover:text-violet-400 transition-colors mb-8"
  >
    {t.blog.backToBlog}
  </a>

  <article>
    <header class="mb-8">
      <div class="flex flex-wrap gap-1.5 mb-3">
        {
          post.data.tags.map((tag) => (
            <span class="px-2 py-0.5 text-xs rounded-full bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400">
              {tag}
            </span>
          ))
        }
      </div>
      <h1 class="text-3xl lg:text-4xl font-bold text-slate-900 dark:text-slate-100 leading-tight mb-3">
        {post.data.title}
      </h1>
      <time
        datetime={post.data.date.toISOString()}
        class="text-sm text-slate-400 dark:text-slate-500"
      >
        {dateFormatter.format(post.data.date)}
      </time>
    </header>

    <div class="prose prose-slate dark:prose-invert max-w-none
                prose-headings:font-semibold prose-headings:tracking-tight
                prose-h2:text-xl prose-h3:text-lg
                prose-pre:bg-transparent prose-pre:p-0
                prose-a:text-violet-700 prose-a:dark:text-violet-400
                prose-hr:border-slate-200 prose-hr:dark:border-slate-800">
      <Content />
    </div>
  </article>
</BlogLayout>
