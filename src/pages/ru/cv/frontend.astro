---
import CvLayout from "../../../layouts/CvLayout.astro";
import CvDocument from "../../../components/CvDocument.astro";
import { ru as t } from "../../../i18n/ru";
import { ENCODED_EMAIL, ENCODED_WHATSAPP } from "../../../utils/email";
import {
  cvSummaryRuFrontend,
  cvSkillsRuFrontend,
  cvExperienceRuFrontend,
  cvEducationRu,
  cvLanguagesRu,
} from "../../../data/cvContent";
---

<CvLayout title="Ivan Tkachenko CV Senior Frontend Engineer RU Frontend" lang="ru">
  <CvDocument
    t={t}
    encodedEmail={ENCODED_EMAIL}
    encodedWhatsapp={ENCODED_WHATSAPP}
    summaryTitle="Обо мне"
    roleTitle="Senior Frontend Engineer (React, Vue, TypeScript)"
    cvSkills={cvSkillsRuFrontend}
    cvSummary={cvSummaryRuFrontend}
    cvExperience={cvExperienceRuFrontend}
    cvEducation={cvEducationRu}
    cvLanguages={cvLanguagesRu}
    educationTitle="Образование"
    languagesTitle="Языки"
  />
</CvLayout>
