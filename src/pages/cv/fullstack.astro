---
import CvLayout from "../../layouts/CvLayout.astro";
import CvDocument from "../../components/CvDocument.astro";
import { en as t } from "../../i18n/en";
import { ENCODED_EMAIL, ENCODED_WHATSAPP } from "../../utils/email";
import {
  cvSummaryEnFullstack,
  cvSkillsEnFullstack,
  cvExperienceEnFullstack,
  cvEducationEn,
  cvLanguagesEn,
} from "../../data/cvContent";
---

<CvLayout title="Ivan Tkachenko CV Senior Full Stack Engineer EN Fullstack" lang="en">
  <CvDocument
    t={t}
    encodedEmail={ENCODED_EMAIL}
    encodedWhatsapp={ENCODED_WHATSAPP}
    summaryTitle="Summary"
    roleTitle="Senior Full Stack Engineer (Go, Node.js, React, Vue)"
    cvSkills={cvSkillsEnFullstack}
    cvSummary={cvSummaryEnFullstack}
    cvExperience={cvExperienceEnFullstack}
    cvEducation={cvEducationEn}
    cvLanguages={cvLanguagesEn}
    educationTitle="Education"
    languagesTitle="Languages"
  />
</CvLayout>
