---
import CvLayout from "../../layouts/CvLayout.astro";
import CvDocument from "../../components/CvDocument.astro";
import { es as t } from "../../i18n/es";
import { ENCODED_EMAIL, ENCODED_WHATSAPP } from "../../utils/email";
import { cvSummaryEs, cvSkillsEs, cvExperienceEs, cvEducationEs, cvLanguagesEs } from "../../data/cvContent";

---

<CvLayout title="Ivan Tkachenko — CV" lang="es">
  <CvDocument
    t={t}
    encodedEmail={ENCODED_EMAIL}
    encodedWhatsapp={ENCODED_WHATSAPP}
    summaryTitle="Sobre mí"
    cvSkills={cvSkillsEs}
    cvSummary={cvSummaryEs}
    cvExperience={cvExperienceEs}
    cvEducation={cvEducationEs}
    cvLanguages={cvLanguagesEs}
    educationTitle="Educación"
    languagesTitle="Idiomas"
  />
</CvLayout>
