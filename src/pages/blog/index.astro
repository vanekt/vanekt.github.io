---
import { getCollection } from "astro:content";
import BlogLayout from "../../layouts/BlogLayout.astro";
import { en as t } from "../../i18n/en";

const posts = (
  await getCollection("blog", ({ data }) => data.lang === "en" && !data.draft)
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const dateFormatter = new Intl.DateTimeFormat("en", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<BlogLayout
  t={t}
  title={`${t.blog.title} — Ivan Tkachenko`}
  description="Frontend engineering: architecture, performance, tooling, and the web platform"
  alternates={[
    { hreflang: "x-default", href: "https://vanekt.github.io/blog/" },
    { hreflang: "en", href: "https://vanekt.github.io/blog/" },
    { hreflang: "ru", href: "https://vanekt.github.io/ru/blog/" },
  ]}
>
  <h1 class="text-3xl font-bold text-slate-900 dark:text-slate-100 mb-2">
    {t.blog.title}
  </h1>
  <p class="text-slate-500 dark:text-slate-400 mb-10">
    Frontend engineering: architecture, performance, tooling, and the web
    platform
  </p>

  <ul class="space-y-8">
    {
      posts.map((post) => (
        <li>
          <article class="group">
            <a
              href={`/blog/${post.data.urlSlug}/`}
              class="flex flex-col sm:flex-row gap-4 sm:gap-8 items-start"
            >
              {post.data.cover && (
                <div class="w-full aspect-video sm:w-40 sm:aspect-video rounded-lg overflow-hidden shrink-0 sm:mt-1.5">
                  <img
                    src={`/blog/covers/${post.data.cover}`}
                    alt=""
                    width="160"
                    height="90"
                    loading="lazy"
                    class="w-full h-full object-cover"
                  />
                </div>
              )}
              <div class="flex-1 min-w-0">
                <time
                  datetime={post.data.date.toISOString()}
                  class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-widest"
                >
                  {dateFormatter.format(post.data.date)}
                </time>
                <h2 class="mt-1 text-xl font-semibold text-slate-900 dark:text-slate-100 group-hover:text-violet-700 dark:group-hover:text-violet-400 transition-colors">
                  {post.data.title}
                </h2>
                <p class="mt-2 text-slate-600 dark:text-slate-400 leading-relaxed">
                  {post.data.description}
                </p>
                <div class="mt-3 flex flex-wrap items-center gap-3">
                  <div class="flex flex-wrap gap-1.5">
                    {post.data.tags.map((tag) => (
                      <span class="px-2 py-0.5 text-xs rounded-full bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400">
                        {tag}
                      </span>
                    ))}
                  </div>
                  <span class="text-xs font-medium text-violet-700 dark:text-violet-400">
                    {t.blog.readMore} →
                  </span>
                </div>
              </div>
            </a>
          </article>
          <hr class="mt-8 border-slate-100 dark:border-slate-800" />
        </li>
      ))
    }
  </ul>
</BlogLayout>
