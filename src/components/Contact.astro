---
import type { Translations } from '../i18n/types'

interface Props {
  t: Translations
}

const { t } = Astro.props
---

<section id="contact" class="max-w-3xl mx-auto px-6 py-16 pb-24">
  <div class="border-t border-slate-200 dark:border-slate-800">
    <h2 class="text-xs font-semibold uppercase tracking-widest mt-8 mb-6 text-violet-700 dark:text-violet-400">
      {t.contact.title}
    </h2>

    <p class="text-base leading-relaxed max-w-md mb-8 text-slate-500 dark:text-slate-400">
      {t.contact.text}
    </p>

    <div class="flex flex-wrap gap-4">
      <a
        href="mailto:hello@vanekt.dev"
        class="inline-flex items-center gap-2 text-sm font-medium px-4 py-2 rounded bg-violet-700 dark:bg-violet-600 hover:bg-violet-800 dark:hover:bg-violet-500 text-white transition-colors"
      >
        {t.contact.email}
      </a>
      <a
        href="https://t.me/vanekt0"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm font-medium px-4 py-2 rounded border border-slate-200 dark:border-slate-700 text-slate-500 dark:text-slate-400 hover:border-slate-400 dark:hover:border-slate-500 hover:text-slate-900 dark:hover:text-slate-100 transition-colors"
      >
        Telegram ↗
      </a>
      <a
        href="https://www.linkedin.com/in/-ivan-tkachenko-/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm font-medium px-4 py-2 rounded border border-slate-200 dark:border-slate-700 text-slate-500 dark:text-slate-400 hover:border-slate-400 dark:hover:border-slate-500 hover:text-slate-900 dark:hover:text-slate-100 transition-colors"
      >
        LinkedIn ↗
      </a>
    </div>
  </div>
</section>

<footer class="max-w-3xl mx-auto px-6 pb-8">
  <p class="text-xs text-slate-300 dark:text-slate-700">
    Built with Astro & Tailwind CSS
  </p>
</footer>
