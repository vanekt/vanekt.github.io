---
import type { Translations } from "../i18n/types";

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section id="contact" class="py-16 px-6 lg:px-12 pb-24">
  <div aria-hidden="true" class="section-sentinel sticky -top-px h-px invisible"></div>
  <h2
    class="section-heading sticky top-0 -mx-6 lg:-mx-12 px-6 lg:px-12 py-4 mb-8 text-xs font-semibold uppercase tracking-widest text-slate-900 dark:text-slate-100 z-10"
  >
    {t.contact.title}
  </h2>

  <p class="text-base leading-relaxed max-w-prose mb-8 text-slate-600 dark:text-slate-400">
    {t.contact.text}
  </p>

  <div class="flex flex-wrap gap-3">
    <button
      type="button"
      id="contact-email-btn"
      aria-label="Email"
      class="inline-flex items-center gap-2 border border-violet-700 dark:border-violet-400 text-violet-700 dark:text-violet-400 bg-transparent hover:bg-violet-700 dark:hover:bg-violet-400 hover:text-white dark:hover:text-slate-950 rounded-lg px-5 py-2.5 text-sm font-medium transition-colors duration-200 cursor-pointer"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="2" y="4" width="20" height="16" rx="2"></rect>
        <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
      </svg>
      <span class="hidden sm:inline">Email</span>
    </button>
    <a
      href="https://t.me/vanekt0"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Telegram"
      class="inline-flex items-center gap-2 text-sm font-medium px-5 py-2.5 rounded-lg border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-400 hover:border-sky-500 dark:hover:border-sky-400 hover:text-sky-500 dark:hover:text-sky-400 transition-colors"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.894 8.221-1.97 9.28c-.145.658-.537.818-1.084.508l-3-2.21-1.447 1.394c-.16.16-.295.295-.605.295l.213-3.053 5.56-5.023c.242-.213-.054-.333-.373-.12l-6.871 4.326-2.962-.924c-.643-.204-.657-.643.136-.953l11.57-4.461c.537-.194 1.006.131.833.94z"></path>
      </svg>
      <span class="hidden sm:inline">Telegram</span>
    </a>
    <a
      href="https://www.linkedin.com/in/-ivan-tkachenko-/"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="LinkedIn"
      class="inline-flex items-center gap-2 text-sm font-medium px-5 py-2.5 rounded-lg border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-400 hover:border-sky-700 dark:hover:border-sky-600 hover:text-sky-700 dark:hover:text-sky-600 transition-colors"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path>
      </svg>
      <span class="hidden sm:inline">LinkedIn</span>
    </a>
    <a
      href="https://github.com/vanekt"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="GitHub"
      class="inline-flex items-center gap-2 text-sm font-medium px-5 py-2.5 rounded-lg border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-400 hover:border-slate-900 dark:hover:border-slate-100 hover:text-slate-900 dark:hover:text-slate-100 transition-colors"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"></path>
      </svg>
      <span class="hidden sm:inline">GitHub</span>
    </a>
  </div>
</section>

<script>
  import { ENCODED_EMAIL } from "../utils/email";
  const btn = document.getElementById("contact-email-btn");
  if (btn) {
    btn.addEventListener("click", () => {
      window.location.href = "mailto:" + atob(ENCODED_EMAIL);
    });
  }
</script>
