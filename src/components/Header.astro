---
import type { Translations } from "../i18n/types";

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const isRu = t.lang === "ru";
const altLangPath = isRu ? "/" : "/ru/";
const altLangLabel = isRu ? "EN" : "RU";
---

<header
  class="sticky top-0 z-50 border-b border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 transition-colors"
>
  <div class="max-w-3xl mx-auto px-6 h-14 flex items-center justify-between">
    <a
      href={isRu ? "/ru/" : "/"}
      class="font-semibold text-sm tracking-wide text-violet-700 dark:text-violet-400"
    >
      Ivan Tkachenko
    </a>

    <nav class="flex items-center gap-5">
      <div
        class="hidden sm:flex items-center gap-5 text-sm text-slate-500 dark:text-slate-400"
      >
        <a
          href="#about"
          class="hover:text-slate-900 dark:hover:text-slate-100 transition-colors"
          >{t.nav.about}</a
        >
        <a
          href="#experience"
          class="hover:text-slate-900 dark:hover:text-slate-100 transition-colors"
          >{t.nav.experience}</a
        >
        <a
          href="#skills"
          class="hover:text-slate-900 dark:hover:text-slate-100 transition-colors"
          >{t.nav.skills}</a
        >
        <a
          href="#contact"
          class="hover:text-slate-900 dark:hover:text-slate-100 transition-colors"
          >{t.nav.contact}</a
        >
      </div>

      <div class="flex items-center gap-3">
        <a
          href={altLangPath}
          class="text-xs font-medium uppercase text-slate-500 dark:text-slate-400 hover:text-violet-700 dark:hover:text-violet-400 transition-colors"
        >
          {altLangLabel}
        </a>

        <button
          onclick="toggleTheme()"
          class="w-7 h-7 flex items-center justify-center text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 transition-colors"
          aria-label="Toggle theme"
        >
          <span id="icon-sun" style="display: block;">
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="12" cy="12" r="5"></circle>
              <line x1="12" y1="1" x2="12" y2="3"></line>
              <line x1="12" y1="21" x2="12" y2="23"></line>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
              <line x1="1" y1="12" x2="3" y2="12"></line>
              <line x1="21" y1="12" x2="23" y2="12"></line>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
            </svg>
          </span>
          <span id="icon-moon" style="display: none;">
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
          </span>
        </button>
      </div>
    </nav>
  </div>
</header>
