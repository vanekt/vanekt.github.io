---
import type { Translations } from "../i18n/types";

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section id="about" class="max-w-3xl mx-auto px-6 py-16">
  <div class="border-t border-slate-200 dark:border-slate-800">
    <h2
      class="text-xs font-semibold uppercase tracking-widest mt-8 mb-6 text-violet-700 dark:text-violet-400"
    >
      {t.about.title}
    </h2>
    <div class="space-y-4 max-w-xl">
      {
        t.about.paragraphs.map((p) => (
          <p class="text-base leading-relaxed text-slate-500 dark:text-slate-400">
            {p}
          </p>
        ))
      }
    </div>
  </div>
</section>
