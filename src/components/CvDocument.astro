---
import type { Translations } from "../i18n/types";
import type { CvExperienceItem } from "../data/cvContent";

interface SkillGroup {
  name: string;
  items: string[];
}

interface Props {
  t: Translations;
  encodedEmail: string;
  encodedWhatsapp: string;
  summaryTitle: string;
  cvSkills: SkillGroup[];
  cvSummary?: string;
  cvExperience?: CvExperienceItem[];
  cvEducation?: string;
  cvLanguages?: string;
  educationTitle?: string;
  languagesTitle?: string;
}

const {
  t,
  encodedEmail,
  encodedWhatsapp,
  summaryTitle,
  cvSkills,
  cvSummary,
  cvExperience,
  cvEducation,
  cvLanguages,
  educationTitle,
  languagesTitle,
} = Astro.props;

const expItems = cvExperience ?? t.experience.items.slice(0, 3);

function buildExpCopy(item: (typeof expItems)[number]): string {
  const parts: string[] = [];
  if ("context" in item && item.context) parts.push(item.context as string);
  parts.push(item.bullets.map((b) => `- ${b}`).join("\n"));
  return parts.join("\n\n");
}

const summaryCopy = cvSummary ?? t.about.paragraphs.join("\n\n");
---

<div
  id="cv-content"
  class="max-w-3xl mx-auto px-10 py-8 font-geist antialiased"
>
  <header class="mb-8">
    <h1 class="text-3xl font-bold text-slate-900 tracking-tight">
      {t.sidebar.name}
    </h1>
    <p class="text-base text-slate-600 mt-1">{t.sidebar.title}</p>
    <div class="mt-3 flex flex-wrap gap-x-5 gap-y-1 text-sm text-slate-500">
      <span>{t.sidebar.location}</span>
      <a id="cv-email-link" href="#" class="text-violet-700"></a>
      <a href="https://github.com/vanekt" class="text-violet-700"
        >github.com/vanekt</a
      >
      <a
        href="https://linkedin.com/in/-ivan-tkachenko-/"
        class="text-violet-700">linkedin.com/in/-ivan-tkachenko-/</a
      >
      <a href="https://t.me/vanekt0" class="text-violet-700">t.me/vanekt0</a>
      <a id="cv-whatsapp-link" href="#" class="text-violet-700"></a>
    </div>
  </header>

  <!-- Summary -->
  <section class="mb-7 group">
    <div
      class="break-after-avoid flex items-center justify-between border-b border-slate-200 pb-1 mb-3"
    >
      <h2
        class="text-xs font-semibold uppercase tracking-widest text-slate-400"
      >
        {summaryTitle}
      </h2>
      <button
        class="copy-btn opacity-0 group-hover:opacity-100 transition-opacity print:hidden p-1 -m-1 rounded text-slate-400 hover:text-slate-600 hover:bg-slate-100"
        data-copy={summaryCopy}
        type="button"
        aria-label="Copy"
      >
        <svg
          class="copy-icon"
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <rect width="8" height="4" x="8" y="2" rx="1" ry="1"></rect>
          <path
            d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"
          ></path>
        </svg>
        <svg
          class="check-icon hidden"
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
      </button>
    </div>
    {
      cvSummary ? (
        <p class="text-sm text-slate-700 leading-snug">{cvSummary}</p>
      ) : (
        t.about.paragraphs.map((p) => (
          <p class="text-sm text-slate-700 leading-snug mb-2">{p}</p>
        ))
      )
    }
  </section>

  <!-- Skills -->
  <section class="mb-7">
    <div class="break-after-avoid border-b border-slate-200 pb-1 mb-3">
      <h2
        class="text-xs font-semibold uppercase tracking-widest text-slate-400"
      >
        {t.skills.title}
      </h2>
    </div>
    <div class="space-y-1.5">
      {
        cvSkills.map((g) => (
          <p class="text-sm text-slate-700">
            <span class="font-semibold text-slate-900">{g.name}: </span>
            <span>{g.items.join(", ")}</span>
          </p>
        ))
      }
    </div>
  </section>

  <!-- Experience -->
  <section>
    <h2
      class="break-after-avoid text-xs font-semibold uppercase tracking-widest text-slate-400 border-b border-slate-200 pb-1 mb-4"
    >
      {t.experience.title}
    </h2>
    <div class="space-y-5">
      {
        expItems.map((item) => (
          <div class="group">
            <div class="break-after-avoid flex items-center justify-between gap-4 mb-0.5">
              <span class="font-semibold text-slate-900">{item.company}</span>
              <div class="flex items-center gap-1.5 shrink-0">
                <span class="text-xs text-slate-400">{item.period}</span>
                <button
                  class="copy-btn opacity-0 group-hover:opacity-100 transition-opacity print:hidden p-1 -m-1 rounded text-slate-400 hover:text-slate-600 hover:bg-slate-100"
                  data-copy={buildExpCopy(item)}
                  type="button"
                  aria-label="Copy"
                >
                  <svg
                    class="copy-icon"
                    xmlns="http://www.w3.org/2000/svg"
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <rect width="8" height="4" x="8" y="2" rx="1" ry="1" />
                    <path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2" />
                  </svg>
                  <svg
                    class="check-icon hidden"
                    xmlns="http://www.w3.org/2000/svg"
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <polyline points="20 6 9 17 4 12" />
                  </svg>
                </button>
              </div>
            </div>
            <div class="break-after-avoid flex items-baseline justify-between gap-4 mb-1.5">
              <span class="text-sm text-slate-600">{item.role}</span>
              <span class="text-xs text-slate-400 shrink-0">
                {item.location}
              </span>
            </div>
            {"context" in item && item.context && (
              <p class="text-xs text-slate-400 italic mb-1.5">{item.context}</p>
            )}
            <ul class="list-disc list-outside pl-4 mb-1.5 marker:text-slate-300">
              {item.bullets.map((b) => (
                <li class="text-sm text-slate-700 leading-snug">{b}</li>
              ))}
            </ul>
            <p class="text-xs text-slate-400 ml-4 mt-2">
              {item.skills.join(" · ")}
            </p>
          </div>
        ))
      }
    </div>
  </section>

  {
    cvEducation && (
      <section class="mt-7">
        <h2 class="break-after-avoid text-xs font-semibold uppercase tracking-widest text-slate-400 border-b border-slate-200 pb-1 mb-3">
          {educationTitle ?? "Education"}
        </h2>
        <p class="text-sm text-slate-700">{cvEducation}</p>
      </section>
    )
  }

  {
    cvLanguages && (
      <section class="mt-5">
        <h2 class="break-after-avoid text-xs font-semibold uppercase tracking-widest text-slate-400 border-b border-slate-200 pb-1 mb-3">
          {languagesTitle ?? "Languages"}
        </h2>
        <p class="text-sm text-slate-700">{cvLanguages}</p>
      </section>
    )
  }
</div>

<script is:inline define:vars={{ encodedEmail, encodedWhatsapp }}>
  const emailLink = document.getElementById("cv-email-link");
  if (emailLink) {
    const email = atob(encodedEmail);
    emailLink.href = "mailto:" + email;
    emailLink.textContent = email;
  }
  const waLink = document.getElementById("cv-whatsapp-link");
  if (waLink) {
    const waNum = atob(encodedWhatsapp).replace(/^\+/, "");
    waLink.href = "https://wa.me/" + waNum;
    waLink.textContent = "wa.me/" + waNum;
  }
</script>

<script>
  const content = document.getElementById("cv-content");
  if (content && new URLSearchParams(location.search).has("edit")) {
    content.setAttribute("contenteditable", "true");
    content.style.outline = "none";
    content
      .querySelectorAll<HTMLElement>(".copy-btn")
      .forEach((btn) => btn.classList.add("hidden"));

    const tagDiffElements = () => {
      let counter = 0;
      content.querySelectorAll<HTMLElement>("h1, p, span, li").forEach((el) => {
        el.dataset.diffId = `d${counter++}`;
      });
    };

    tagDiffElements();
    const baseSnapshot = new Map<string, string>();
    content.querySelectorAll<HTMLElement>("[data-diff-id]").forEach((el) => {
      baseSnapshot.set(el.dataset.diffId!, el.textContent ?? "");
    });
    const baseHtml = content.innerHTML;

    interface Revision {
      name: string;
      html: string;
    }

    const storageKey = `cv-revisions:${document.documentElement.lang}`;

    function loadRevisions(): Revision[] {
      try {
        return JSON.parse(localStorage.getItem(storageKey) ?? "[]");
      } catch {
        return [];
      }
    }

    function saveRevisions(revisions: Revision[]) {
      localStorage.setItem(storageKey, JSON.stringify(revisions));
    }

    let activeIndex: number | null = null;

    const revParam = new URLSearchParams(location.search).get("v");
    if (revParam !== null) {
      const revisions = loadRevisions();
      const rev = revisions[Number(revParam)];
      if (rev) {
        content.innerHTML = rev.html;
        tagDiffElements();
        activeIndex = Number(revParam);
      }
    }

    function setRevParam(index: number | null) {
      const url = new URL(location.href);
      if (index === null) url.searchParams.delete("v");
      else url.searchParams.set("v", String(index));
      history.replaceState(null, "", url);
    }

    const toolbar = document.createElement("div");
    toolbar.className = "print:hidden mb-4 text-sm";
    toolbar.innerHTML =
      '<div class="flex flex-wrap items-center gap-2 mb-2">' +
      '<div class="flex items-center gap-2">' +
      '<button type="button" class="rev-save-as border border-slate-300 rounded px-3 py-1 hover:bg-slate-100">Save as…</button>' +
      '<button type="button" class="rev-save border border-slate-300 rounded px-3 py-1 hover:bg-slate-100">Save</button>' +
      "</div>" +
      '<div class="flex items-center gap-2 border-l border-slate-300 pl-2">' +
      '<button type="button" class="rev-diff border border-slate-300 rounded px-3 py-1 hover:bg-slate-100">Diff vs base</button>' +
      "</div>" +
      '<div class="flex items-center gap-2 border-l border-slate-300 pl-2">' +
      '<button type="button" class="rev-export border border-slate-300 rounded px-3 py-1 hover:bg-slate-100">Export</button>' +
      '<button type="button" class="rev-import border border-slate-300 rounded px-3 py-1 hover:bg-slate-100">Import</button>' +
      '<input type="file" accept="application/json" class="rev-import-input hidden" />' +
      "</div>" +
      "</div>" +
      '<div class="rev-list flex flex-wrap items-center gap-2"></div>';
    content.insertAdjacentElement("beforebegin", toolbar);

    const saveAsBtn = toolbar.querySelector<HTMLButtonElement>(".rev-save-as")!;
    const saveBtn = toolbar.querySelector<HTMLButtonElement>(".rev-save")!;
    const diffBtn = toolbar.querySelector<HTMLButtonElement>(".rev-diff")!;
    const exportBtn = toolbar.querySelector<HTMLButtonElement>(".rev-export")!;
    const importBtn = toolbar.querySelector<HTMLButtonElement>(".rev-import")!;
    const importInput = toolbar.querySelector<HTMLInputElement>(".rev-import-input")!;
    const list = toolbar.querySelector<HTMLDivElement>(".rev-list")!;

    exportBtn.addEventListener("click", () => {
      const blob = new Blob([JSON.stringify(loadRevisions(), null, 2)], {
        type: "application/json",
      });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download = `cv-revisions-${document.documentElement.lang}.json`;
      a.click();
      URL.revokeObjectURL(url);
    });

    importBtn.addEventListener("click", () => importInput.click());

    importInput.addEventListener("change", () => {
      const file = importInput.files?.[0];
      importInput.value = "";
      if (!file) return;
      file.text().then((text) => {
        try {
          const imported: Revision[] = JSON.parse(text);
          const startIndex = loadRevisions().length;
          const merged = loadRevisions().concat(imported);
          saveRevisions(merged);
          const rev = merged[startIndex];
          if (rev) {
            content.innerHTML = rev.html;
            tagDiffElements();
            activeIndex = startIndex;
            setRevParam(activeIndex);
          }
          renderList();
        } catch {
          alert("Failed to read revisions file");
        }
      });
    });

    function escapeHtml(text: string): string {
      const div = document.createElement("div");
      div.textContent = text;
      return div.innerHTML;
    }

    function diffWordsHtml(base: string, current: string): string {
      const a = base.split(/(\s+)/);
      const b = current.split(/(\s+)/);
      const dp: number[][] = Array.from({ length: a.length + 1 }, () =>
        Array.from({ length: b.length + 1 }, () => 0),
      );
      for (let i = a.length - 1; i >= 0; i--) {
        for (let j = b.length - 1; j >= 0; j--) {
          dp[i][j] = a[i] === b[j] ? dp[i + 1][j + 1] + 1 : Math.max(dp[i + 1][j], dp[i][j + 1]);
        }
      }
      let html = "";
      let i = 0;
      let j = 0;
      while (i < a.length && j < b.length) {
        if (a[i] === b[j]) {
          html += escapeHtml(b[j]);
          i++;
          j++;
        } else if (dp[i + 1][j] >= dp[i][j + 1]) {
          html += `<del class="cv-diff-del line-through text-red-400">${escapeHtml(a[i])}</del>`;
          i++;
        } else {
          html += `<mark class="cv-diff-mark bg-yellow-200">${escapeHtml(b[j])}</mark>`;
          j++;
        }
      }
      while (i < a.length) {
        html += `<del class="cv-diff-del line-through text-red-400">${escapeHtml(a[i])}</del>`;
        i++;
      }
      while (j < b.length) {
        html += `<mark class="cv-diff-mark bg-yellow-200">${escapeHtml(b[j])}</mark>`;
        j++;
      }
      return html;
    }

    const clearDiffMarkup = () => {
      content.querySelectorAll<HTMLElement>("del.cv-diff-del").forEach((el) => el.remove());
      content.querySelectorAll<HTMLElement>("mark.cv-diff-mark").forEach((mark) => {
        mark.replaceWith(document.createTextNode(mark.textContent ?? ""));
      });
      content.querySelectorAll<HTMLElement>("[data-diff-id]").forEach((el) => {
        el.classList.remove("bg-yellow-200");
        el.normalize();
      });
    };

    diffBtn.addEventListener("click", () => {
      clearDiffMarkup();
      content.querySelectorAll<HTMLElement>("[data-diff-id]").forEach((el) => {
        if (el.querySelector("[data-diff-id]")) return;
        const base = baseSnapshot.get(el.dataset.diffId!);
        const current = el.textContent ?? "";
        if (base === undefined || current === base) return;
        el.innerHTML = diffWordsHtml(base, current);
      });
    });

    function renderList() {
      const revisions = loadRevisions();
      const baseItem =
        `<span class="inline-flex items-center gap-1 border rounded px-2 py-1 ${activeIndex === null ? "border-violet-700" : "border-slate-300"}">` +
        `<button type="button" class="rev-base">Base</button>` +
        `</span>`;
      list.innerHTML =
        baseItem +
        revisions
          .map(
            (r, i) =>
              `<span class="inline-flex items-center gap-1 border rounded px-2 py-1 ${i === activeIndex ? "border-violet-700" : "border-slate-300"}">` +
              `<button type="button" class="rev-load" data-index="${i}">${r.name}</button>` +
              `<button type="button" class="rev-rename text-slate-400 hover:text-slate-600" data-index="${i}">✎</button>` +
              `<button type="button" class="rev-del text-slate-400 hover:text-red-600" data-index="${i}">×</button>` +
              `</span>`,
          )
          .join("");
    }

    renderList();

    list.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;
      if (target.classList.contains("rev-base")) {
        clearDiffMarkup();
        content.innerHTML = baseHtml;
        tagDiffElements();
        activeIndex = null;
        setRevParam(null);
        renderList();
        return;
      }
      const index = target.dataset.index;
      if (index === undefined) return;
      const revisions = loadRevisions();
      const rev = revisions[Number(index)];
      if (target.classList.contains("rev-load")) {
        if (rev) {
          content.innerHTML = rev.html;
          tagDiffElements();
          activeIndex = Number(index);
          setRevParam(activeIndex);
          renderList();
        }
      } else if (target.classList.contains("rev-rename")) {
        if (rev) {
          const name = prompt("Rename revision:", rev.name);
          if (name) {
            rev.name = name;
            saveRevisions(revisions);
            renderList();
          }
        }
      } else if (target.classList.contains("rev-del")) {
        revisions.splice(Number(index), 1);
        saveRevisions(revisions);
        if (activeIndex !== null) {
          if (Number(index) === activeIndex) activeIndex = null;
          else if (Number(index) < activeIndex) activeIndex -= 1;
          setRevParam(activeIndex);
        }
        renderList();
      }
    });

    saveAsBtn.addEventListener("click", () => {
      const name = prompt("Revision name:");
      if (!name) return;
      clearDiffMarkup();
      const revisions = loadRevisions();
      revisions.push({ name, html: content.innerHTML });
      saveRevisions(revisions);
      activeIndex = revisions.length - 1;
      setRevParam(activeIndex);
      renderList();
    });

    saveBtn.addEventListener("click", () => {
      const revisions = loadRevisions();
      if (activeIndex === null || !revisions[activeIndex]) {
        saveAsBtn.click();
        return;
      }
      clearDiffMarkup();
      revisions[activeIndex].html = content.innerHTML;
      saveRevisions(revisions);
      renderList();
    });
  }

  document.querySelectorAll<HTMLButtonElement>(".copy-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const text = btn.dataset.copy ?? "";
      navigator.clipboard.writeText(text).then(() => {
        const copyIcon = btn.querySelector(".copy-icon");
        const checkIcon = btn.querySelector(".check-icon");
        copyIcon?.classList.add("hidden");
        checkIcon?.classList.remove("hidden");
        btn.classList.add("text-green-600");
        setTimeout(() => {
          copyIcon?.classList.remove("hidden");
          checkIcon?.classList.add("hidden");
          btn.classList.remove("text-green-600");
        }, 1500);
      });
    });
  });
</script>
