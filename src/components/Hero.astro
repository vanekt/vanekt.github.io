---
import type { Translations } from '../i18n/types'

interface Props {
  t: Translations
}

const { t } = Astro.props
---

<section class="max-w-3xl mx-auto px-6 pt-24 pb-20">
  <p class="text-sm font-mono mb-3 text-violet-700 dark:text-violet-400">Hi, I'm</p>
  <h1 class="text-4xl sm:text-5xl font-bold mb-3 tracking-tight text-slate-900 dark:text-slate-100">
    {t.hero.name}
  </h1>
  <h2 class="text-xl sm:text-2xl font-medium mb-6 text-slate-500 dark:text-slate-400">
    {t.hero.title}
  </h2>
  <p class="text-base leading-relaxed max-w-xl mb-8 text-slate-500 dark:text-slate-400">
    {t.hero.pitch}
  </p>
  <div class="flex flex-wrap items-center gap-4">
    <span class="inline-flex items-center gap-1.5 text-sm px-3 py-1.5 rounded-full border border-violet-700 dark:border-violet-400 text-violet-700 dark:text-violet-400">
      <span class="w-1.5 h-1.5 rounded-full bg-green-400 inline-block"></span>
      {t.hero.available}
    </span>
    <div class="flex items-center gap-4">
      <a
        href="https://github.com/vanekt"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-slate-500 dark:text-slate-400 hover:text-violet-700 dark:hover:text-violet-400 transition-colors"
      >
        GitHub ↗
      </a>
      <a
        href="https://www.linkedin.com/in/-ivan-tkachenko-/"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-slate-500 dark:text-slate-400 hover:text-violet-700 dark:hover:text-violet-400 transition-colors"
      >
        LinkedIn ↗
      </a>
      <a
        href="https://t.me/vanekt0"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-slate-500 dark:text-slate-400 hover:text-violet-700 dark:hover:text-violet-400 transition-colors"
      >
        Telegram ↗
      </a>
    </div>
  </div>
</section>
