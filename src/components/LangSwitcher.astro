---
import type { Translations } from "../i18n/types";

interface Props {
  t: Translations;
  class?: string;
}

const { t, class: className } = Astro.props;
const isRu = t.lang === "ru";
const altLangPath = isRu ? "/" : "/ru/";
const altLangLabel = isRu ? "EN" : "RU";
---

<a
  href={altLangPath}
  class:list={[
    "w-9 h-9 flex items-center justify-center rounded-lg text-xs font-medium uppercase tracking-widest text-slate-500 dark:text-slate-400 hover:text-violet-700 dark:hover:text-violet-400 transition-colors",
    className,
  ]}
>
  {altLangLabel}
</a>
