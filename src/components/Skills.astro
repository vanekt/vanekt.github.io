---
import type { Translations } from '../i18n/types'

interface Props {
  t: Translations
}

const { t } = Astro.props
---

<section id="skills" class="max-w-3xl mx-auto px-6 py-16">
  <div class="border-t border-slate-200 dark:border-slate-800">
    <h2 class="text-xs font-semibold uppercase tracking-widest mt-8 mb-8 text-violet-700 dark:text-violet-400">
      {t.skills.title}
    </h2>

    <div class="space-y-6">
      {t.skills.groups.map((group) => (
        <div>
          <h3 class="text-xs font-medium uppercase tracking-wider mb-3 text-slate-400 dark:text-slate-500">
            {group.name}
          </h3>
          <div class="flex flex-wrap gap-2">
            {group.items.map((item) => (
              <span class="text-sm px-3 py-1 rounded border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 text-slate-700 dark:text-slate-300">
                {item}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
