---
import type { Translations } from "../i18n/types";
import ThemeToggle from "./ThemeToggle.astro";
import LangSwitcher from "./LangSwitcher.astro";
import SidebarProfile from "./SidebarProfile.astro";

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const isRu = t.lang === "ru";
const homeUrl = isRu ? "/ru/" : "/";

const navItems = [
  { key: "about", label: t.nav.about },
  { key: "experience", label: t.nav.experience },
  { key: "projects", label: t.nav.projects },
  { key: "skills", label: t.nav.skills },
  { key: "contact", label: t.nav.contact },
];
---

<aside
  class="sidebar hidden lg:flex fixed top-0 left-0 h-screen flex-col
         border-r border-slate-100 dark:border-slate-800/50
         bg-white dark:bg-slate-950 z-40 px-10 py-12"
>
  <!-- Name + title + location/status -->
  <div>
    <a href={homeUrl} class="block mb-3">
      <h1
        class="text-4xl lg:text-5xl font-bold tracking-tight text-slate-900 dark:text-slate-100 leading-tight"
      >
        {t.sidebar.name}
      </h1>
    </a>
    <SidebarProfile t={t} />
  </div>

  <!-- Navigation -->
  <nav aria-label="Main navigation" class="mt-10">
    <ul class="space-y-1">
      {
        navItems.map((item) => (
          <li>
            <a
              href={`#${item.key}`}
              data-nav={item.key}
              class="nav-item inline-flex items-center gap-3 px-2 py-1.5 text-xs font-medium tracking-widest uppercase transition-colors"
            >
              <span class="nav-line" />
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <!-- Bottom row: socials left, controls right -->
  <div class="mt-auto border-t border-slate-100 dark:border-slate-800 pt-5">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-1">
        <ThemeToggle />
        <LangSwitcher t={t} />
      </div>
      <div class="flex items-center gap-1">
      <button
        type="button"
        id="sidebar-email-btn"
        aria-label="Email"
        class="p-2.5 text-slate-400 dark:text-slate-500 hover:text-violet-700 dark:hover:text-violet-400 hover:scale-110 transition-all duration-150 cursor-pointer"
      >
        <svg
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="2" y="4" width="20" height="16" rx="2"></rect>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
        </svg>
      </button>
      <a
        href="https://github.com/vanekt"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
        class="p-2.5 text-slate-400 dark:text-slate-500 hover:text-slate-900 dark:hover:text-slate-100 hover:scale-110 transition-all duration-150"
      >
        <svg
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"
          ></path>
        </svg>
      </a>
      <a
        href="https://t.me/vanekt0"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Telegram"
        class="p-2.5 text-slate-400 dark:text-slate-500 hover:text-sky-500 dark:hover:text-sky-400 hover:scale-110 transition-all duration-150"
      >
        <svg
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.894 8.221-1.97 9.28c-.145.658-.537.818-1.084.508l-3-2.21-1.447 1.394c-.16.16-.295.295-.605.295l.213-3.053 5.56-5.023c.242-.213-.054-.333-.373-.12l-6.871 4.326-2.962-.924c-.643-.204-.657-.643.136-.953l11.57-4.461c.537-.194 1.006.131.833.94z"
          ></path>
        </svg>
      </a>
      <a
        href="https://www.linkedin.com/in/-ivan-tkachenko-/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
        class="p-2.5 text-slate-400 dark:text-slate-500 hover:text-sky-700 dark:hover:text-sky-600 hover:scale-110 transition-all duration-150"
      >
        <svg
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
          ></path>
        </svg>
      </a>
      </div>
    </div>
  </div>
</aside>

<script is:inline>
  document.addEventListener("DOMContentLoaded", function () {
    const navLinks = document.querySelectorAll("[data-nav]");
    if (!navLinks.length) return;

    const sections = Array.from(navLinks)
      .map(function (link) {
        const id = link.getAttribute("data-nav");
        return id ? document.getElementById(id) : null;
      })
      .filter(Boolean);

    if (!sections.length) return;

    function setActive(id) {
      navLinks.forEach(function (link) {
        link.classList.toggle("active", link.getAttribute("data-nav") === id);
      });
    }

    function getActiveId() {
      // If scrolled to the bottom, the last section is active regardless of threshold.
      if (
        window.innerHeight + window.scrollY >=
        document.documentElement.scrollHeight - 50
      ) {
        return sections[sections.length - 1].id;
      }
      const threshold = window.innerHeight * 0.35;
      let id = sections[0].id;
      for (let i = sections.length - 1; i >= 0; i--) {
        if (sections[i].getBoundingClientRect().top <= threshold) {
          id = sections[i].id;
          break;
        }
      }
      return id;
    }

    function updateActive() {
      const id = getActiveId();
      // Keep hash in sync so URL reflects current section.
      // replaceState does NOT trigger hashchange, so no loop.
      // Only update hash if a hash was already present (don't add #about on clean load).
      if (window.location.hash && window.location.hash.slice(1) !== id) {
        history.replaceState(null, "", "#" + id);
      }
      setActive(id);
    }

    // When a nav link is clicked: immediately set the target as active and
    // suppress scroll-based updates until smooth scrolling finishes.
    // "Scroll end" is detected by 150ms silence in scroll events.
    let suppressScroll = false;
    let scrollEndTimer = null;

    const navLinksArray = Array.from(navLinks);

    navLinksArray.forEach(function (link, index) {
      link.addEventListener("click", function (e) {
        e.preventDefault();
        const id = link.getAttribute("data-nav");
        setActive(id);
        if (id && window.location.hash.slice(1) !== id) {
          history.replaceState(null, "", "#" + id);
        }
        const target = id ? document.getElementById(id) : null;
        if (target) {
          target.scrollIntoView({ behavior: "smooth" });
        }
        suppressScroll = true;
        clearTimeout(scrollEndTimer);
        link.focus();
      });

      link.addEventListener("keydown", function (e) {
        if (e.key === "ArrowDown") {
          e.preventDefault();
          const next = navLinksArray[index + 1];
          if (next) {
            next.focus();
          }
        } else if (e.key === "ArrowUp") {
          e.preventDefault();
          const prev = navLinksArray[index - 1];
          if (prev) {
            prev.focus();
          }
        }
      });
    });

    window.addEventListener(
      "scroll",
      function () {
        if (suppressScroll) {
          clearTimeout(scrollEndTimer);
          scrollEndTimer = setTimeout(function () {
            suppressScroll = false;
            updateActive();
          }, 150);
          return;
        }
        updateActive();
      },
      { passive: true },
    );

    // Initial state: prefer existing hash (e.g. opening /#skills directly),
    // otherwise detect from scroll position.
    const initHash = window.location.hash.slice(1);
    if (initHash && document.getElementById(initHash)) {
      setActive(initHash);
    } else {
      updateActive();
    }
  });
</script>

<script>
  import { ENCODED_EMAIL } from "../utils/email";
  const btn = document.getElementById("sidebar-email-btn");
  if (btn) {
    btn.addEventListener("click", () => {
      window.location.href = "mailto:" + atob(ENCODED_EMAIL);
    });
  }
</script>
