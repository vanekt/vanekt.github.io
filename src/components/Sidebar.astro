---
import type { Translations } from "../i18n/types";
import ThemeToggle from "./ThemeToggle.astro";
import LangSwitcher from "./LangSwitcher.astro";
import SidebarProfile from "./SidebarProfile.astro";
import IconDownload from "./icons/IconDownload.astro";
import IconEmail from "./icons/IconEmail.astro";
import IconGitHub from "./icons/IconGitHub.astro";
import IconTelegram from "./icons/IconTelegram.astro";
import IconLinkedIn from "./icons/IconLinkedIn.astro";

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const isRu = t.lang === "ru";
const homeUrl = isRu ? "/ru/" : "/";

const navItems = [
  { key: "about", label: t.nav.about },
  { key: "experience", label: t.nav.experience },
  { key: "projects", label: t.nav.projects },
  { key: "skills", label: t.nav.skills },
  { key: "contact", label: t.nav.contact },
];
---

<aside
  class="sidebar hidden lg:flex fixed top-0 left-0 h-screen flex-col
         border-r border-slate-100 dark:border-slate-800/50
         bg-white dark:bg-slate-950 z-40 px-10 py-12"
>
  <!-- Name + title + location/status -->
  <div>
    <a href={homeUrl} class="block mb-3">
      <h1
        class="text-4xl lg:text-5xl font-bold tracking-tight text-slate-900 dark:text-slate-100 leading-tight"
      >
        {t.sidebar.name}
      </h1>
    </a>
    <SidebarProfile t={t} />
  </div>

  <!-- Navigation -->
  <nav aria-label="Main navigation" class="mt-10">
    <ul class="space-y-1">
      {
        navItems.map((item) => (
          <li>
            <a
              href={`#${item.key}`}
              data-nav={item.key}
              class="nav-item inline-flex items-center gap-3 px-2 py-1.5 text-xs font-medium tracking-widest uppercase transition-colors"
            >
              <span class="nav-line" />
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <!-- Bottom row: socials left, controls right -->
  <div class="mt-auto border-t border-slate-100 dark:border-slate-800 pt-5">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-1">
        <ThemeToggle />
        <LangSwitcher t={t} />
        <a
          href={isRu ? "/cv-ru.pdf" : "/cv.pdf"}
          download={isRu ? "Ivan Tkachenko - Senior Frontend & Full Stack Engineer RU.pdf" : "Ivan Tkachenko - Senior Frontend & Full Stack Engineer EN.pdf"}
          aria-label={t.contact.downloadCv}
          class="h-9 px-2 flex items-center gap-1.5 rounded-lg text-violet-700 dark:text-violet-400 hover:text-violet-900 dark:hover:text-violet-300 transition-colors"
        >
          <IconDownload />
          <span class="text-xs font-medium">{t.contact.downloadCv}</span>
        </a>
      </div>
      <div class="flex items-center gap-1">
      <button
        type="button"
        id="sidebar-email-btn"
        aria-label="Email"
        class="p-2.5 text-slate-400 dark:text-slate-500 hover:text-violet-700 dark:hover:text-violet-400 hover:scale-110 transition-all duration-150 cursor-pointer"
      >
        <IconEmail />
      </button>
      <a
        href="https://github.com/vanekt"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
        class="p-2.5 text-slate-400 dark:text-slate-500 hover:text-slate-900 dark:hover:text-slate-100 hover:scale-110 transition-all duration-150"
      >
        <IconGitHub />
      </a>
      <a
        href="https://t.me/vanekt0"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Telegram"
        class="p-2.5 text-slate-400 dark:text-slate-500 hover:text-sky-500 dark:hover:text-sky-400 hover:scale-110 transition-all duration-150"
      >
        <IconTelegram />
      </a>
      <a
        href="https://www.linkedin.com/in/-ivan-tkachenko-/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
        class="p-2.5 text-slate-400 dark:text-slate-500 hover:text-sky-700 dark:hover:text-sky-600 hover:scale-110 transition-all duration-150"
      >
        <IconLinkedIn />
      </a>
      </div>
    </div>
  </div>
</aside>

<script is:inline>
  document.addEventListener("DOMContentLoaded", function () {
    const navLinks = document.querySelectorAll("[data-nav]");
    if (!navLinks.length) return;

    const sections = Array.from(navLinks)
      .map(function (link) {
        const id = link.getAttribute("data-nav");
        return id ? document.getElementById(id) : null;
      })
      .filter(Boolean);

    if (!sections.length) return;

    function setActive(id) {
      navLinks.forEach(function (link) {
        link.classList.toggle("active", link.getAttribute("data-nav") === id);
      });
    }

    function getActiveId() {
      // If scrolled to the bottom, the last section is active regardless of threshold.
      if (
        window.innerHeight + window.scrollY >=
        document.documentElement.scrollHeight - 50
      ) {
        return sections[sections.length - 1].id;
      }
      const threshold = window.innerHeight * 0.35;
      let id = sections[0].id;
      for (let i = sections.length - 1; i >= 0; i--) {
        if (sections[i].getBoundingClientRect().top <= threshold) {
          id = sections[i].id;
          break;
        }
      }
      return id;
    }

    function updateActive() {
      const id = getActiveId();
      // Keep hash in sync so URL reflects current section.
      // replaceState does NOT trigger hashchange, so no loop.
      // Only update hash if a hash was already present (don't add #about on clean load).
      if (window.location.hash && window.location.hash.slice(1) !== id) {
        history.replaceState(null, "", "#" + id);
      }
      setActive(id);
    }

    // When a nav link is clicked: immediately set the target as active and
    // suppress scroll-based updates until smooth scrolling finishes.
    // "Scroll end" is detected by 150ms silence in scroll events.
    let suppressScroll = false;
    let scrollEndTimer = null;

    const navLinksArray = Array.from(navLinks);

    navLinksArray.forEach(function (link, index) {
      link.addEventListener("click", function (e) {
        e.preventDefault();
        const id = link.getAttribute("data-nav");
        setActive(id);
        if (id && window.location.hash.slice(1) !== id) {
          history.replaceState(null, "", "#" + id);
        }
        const target = id ? document.getElementById(id) : null;
        if (target) {
          target.scrollIntoView({ behavior: "smooth" });
        }
        suppressScroll = true;
        clearTimeout(scrollEndTimer);
        link.focus();
      });

      link.addEventListener("keydown", function (e) {
        if (e.key === "ArrowDown") {
          e.preventDefault();
          const next = navLinksArray[index + 1];
          if (next) {
            next.focus();
          }
        } else if (e.key === "ArrowUp") {
          e.preventDefault();
          const prev = navLinksArray[index - 1];
          if (prev) {
            prev.focus();
          }
        }
      });
    });

    window.addEventListener(
      "scroll",
      function () {
        if (suppressScroll) {
          clearTimeout(scrollEndTimer);
          scrollEndTimer = setTimeout(function () {
            suppressScroll = false;
            updateActive();
          }, 150);
          return;
        }
        updateActive();
      },
      { passive: true },
    );

    // Initial state: prefer existing hash (e.g. opening /#skills directly),
    // otherwise detect from scroll position.
    const initHash = window.location.hash.slice(1);
    if (initHash && document.getElementById(initHash)) {
      setActive(initHash);
    } else {
      updateActive();
    }
  });
</script>

<script>
  import { ENCODED_EMAIL } from "../utils/email";
  const btn = document.getElementById("sidebar-email-btn");
  if (btn) {
    btn.addEventListener("click", () => {
      window.location.href = "mailto:" + atob(ENCODED_EMAIL);
    });
  }
</script>
