---
import type { Translations } from "../i18n/types";

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section id="experience" class="py-16 lg:px-12">
  <div
    aria-hidden="true"
    class="section-sentinel sticky -top-px h-px invisible"
  >
  </div>
  <h2
    class="section-heading sticky top-0 lg:-mx-12 px-6 lg:px-12 py-4 mb-8 text-xs font-semibold uppercase tracking-widest text-slate-900 dark:text-slate-100 z-10"
  >
    {t.experience.title}
  </h2>

  <div class="space-y-3">
    {
      t.experience.items.map((item) => (
        <article class="group animate-on-scroll rounded-lg p-6 border border-transparent hover:border-slate-200 dark:hover:border-slate-800 hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors duration-200">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1 mb-1">
            <div>
              <span class="font-medium text-base text-slate-900 dark:text-slate-100">
                {item.role}
              </span>
              <span
                class="mx-1.5 text-slate-300 dark:text-slate-700"
                aria-hidden="true"
              >
                |
              </span>
              {item.url ? (
                <a
                  href={item.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm font-medium text-violet-700 dark:text-violet-400 hover:underline"
                >
                  {item.company}
                </a>
              ) : (
                <span class="text-sm font-medium text-violet-700 dark:text-violet-400">
                  {item.company}
                </span>
              )}
              <span
                class="hidden sm:inline mx-1.5 text-slate-300 dark:text-slate-700"
                aria-hidden="true"
              >
                |
              </span>
              <span class="block sm:inline mt-1 sm:mt-0 text-xs text-slate-400 dark:text-slate-500">
                {item.location}
              </span>
            </div>
            <p class="order-first sm:order-last text-xs font-mono tracking-wide uppercase text-slate-400 dark:text-slate-500 shrink-0">
              {item.period}
            </p>
          </div>

          <p class="mt-3 text-sm text-slate-400 dark:text-slate-500 italic">{item.context}</p>

          <ul class="mt-4 space-y-2">
            {item.bullets.map((bullet) => (
              <li class="flex items-start gap-3 text-sm leading-relaxed text-slate-500 dark:text-slate-400">
                <span
                  class="mt-2 w-1 h-1 rounded-full shrink-0 bg-violet-700 dark:bg-violet-400"
                  aria-hidden="true"
                />
                <span>{bullet}</span>
              </li>
            ))}
          </ul>

          <div class="flex flex-wrap gap-2 mt-8">
            {item.skills.map((skill) => (
              <span class="text-xs font-mono bg-violet-50 dark:bg-violet-400/10 text-violet-700 dark:text-violet-400 rounded-full px-3 py-1">
                {skill}
              </span>
            ))}
          </div>
        </article>
      ))
    }
  </div>
</section>

<script is:inline>
  // Scroll animations with stagger for experience cards
  (function () {
    const items = document.querySelectorAll("#experience .animate-on-scroll");
    if (!items.length) return;
    const observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry, i) {
          if (entry.isIntersecting) {
            setTimeout(function () {
              entry.target.classList.add("is-visible");
            }, i * 80);
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: "0px 0px -50px 0px" },
    );
    items.forEach(function (item) {
      observer.observe(item);
    });
  })();
</script>
