---
import type { Translations } from "../i18n/types";

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section id="experience" class="max-w-3xl mx-auto px-6 py-16">
  <div class="border-t border-slate-200 dark:border-slate-800">
    <h2
      class="text-xs font-semibold uppercase tracking-widest mt-8 mb-8 text-violet-700 dark:text-violet-400"
    >
      {t.experience.title}
    </h2>

    <div class="space-y-10">
      {
        t.experience.items.map((item) => (
          <div>
            <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-1">
              <div>
                <span class="font-semibold text-base text-slate-900 dark:text-slate-100">
                  {item.role}
                </span>
                <span class="mx-2 text-slate-300 dark:text-slate-700">·</span>
                <span class="text-sm font-medium text-violet-700 dark:text-violet-400">
                  {item.company}
                </span>
              </div>
              <div class="text-xs text-slate-400 dark:text-slate-500 shrink-0">
                {item.period} · {item.location}
              </div>
            </div>

            <ul class="mt-3 space-y-1.5">
              {item.bullets.map((bullet) => (
                <li class="flex gap-2 text-sm leading-relaxed text-slate-500 dark:text-slate-400">
                  <span class="mt-1.5 w-1 h-1 rounded-full shrink-0 bg-violet-700 dark:bg-violet-400" />
                  <span>{bullet}</span>
                </li>
              ))}
            </ul>

            <div class="flex flex-wrap gap-1.5 mt-4">
              {item.skills.map((skill) => (
                <span class="text-xs px-2 py-0.5 rounded border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 text-slate-500 dark:text-slate-400">
                  {skill}
                </span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
