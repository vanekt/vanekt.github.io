---
import type { Translations } from "../i18n/types";
import IconGitHub from "./icons/IconGitHub.astro";

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section id="projects" class="py-16 lg:px-12">
  <div
    aria-hidden="true"
    class="section-sentinel sticky -top-px h-px invisible"
  >
  </div>
  <h2
    class="section-heading sticky top-0 lg:-mx-12 px-6 lg:px-12 py-4 mb-8 text-xs font-semibold uppercase tracking-widest text-slate-900 dark:text-slate-100 z-10"
  >
    {t.projects.title}
  </h2>

  <div class="space-y-4">
    {
      t.projects.items.map((project) => (
        <article class="group animate-on-scroll rounded-lg p-6 border border-transparent hover:border-slate-200 dark:hover:border-slate-800 hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors duration-200">
          <div class="flex items-start justify-between gap-4 mb-3">
            <div class="flex items-center gap-3 min-w-0">
              {project.logo ? (
                <img
                  src={project.logo}
                  alt={`${project.name} logo`}
                  width="24"
                  height="24"
                  loading="lazy"
                  decoding="async"
                  class="shrink-0 size-6 rounded object-contain"
                />
              ) : (
                <span class="shrink-0 size-6 rounded bg-violet-100 dark:bg-violet-400/20 text-violet-700 dark:text-violet-400 text-xs font-semibold flex items-center justify-center">
                  {project.name[0].toUpperCase()}
                </span>
              )}
              <h3 class="text-base font-medium text-slate-900 dark:text-slate-100">
                {project.name}
              </h3>
            </div>
            <div class="flex items-center gap-3 shrink-0">
              {project.github && (
                <a
                  href={project.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`${project.name} on GitHub`}
                  class="text-slate-400 dark:text-slate-500 hover:text-violet-700 dark:hover:text-violet-400 transition-colors"
                >
                  <IconGitHub width={16} height={16} />
                </a>
              )}
              {project.demo && (
                <a
                  href={project.demo}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`${project.name} live demo`}
                  class="text-xs font-medium text-slate-400 dark:text-slate-500 hover:text-violet-700 dark:hover:text-violet-400 transition-colors"
                >
                  ↗
                </a>
              )}
            </div>
          </div>
          <p class="text-sm leading-relaxed text-slate-500 dark:text-slate-400 mb-4">
            {project.description}
          </p>
          <div class="flex flex-wrap gap-2">
            {project.stack.map((tech) => (
              <span class="text-xs font-mono bg-violet-50 dark:bg-violet-400/10 text-violet-700 dark:text-violet-400 rounded-full px-3 py-1 hover:bg-violet-100 dark:hover:bg-violet-400/20 transition-colors cursor-default">
                {tech}
              </span>
            ))}
          </div>
        </article>
      ))
    }
  </div>
</section>

<script is:inline>
  (function () {
    const items = document.querySelectorAll("#projects .animate-on-scroll");
    if (!items.length) return;
    const observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry, i) {
          if (entry.isIntersecting) {
            setTimeout(function () {
              entry.target.classList.add("is-visible");
            }, i * 100);
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15, rootMargin: "0px 0px -50px 0px" },
    );
    items.forEach(function (item) {
      observer.observe(item);
    });
  })();
</script>
